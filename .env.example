# AI News Aggregator - Configuration Template
# Copy to .env and fill with your values

# ================================
# App Configuration
# ================================
DEBUG=false
LOG_LEVEL=INFO

# App info
APP_NAME="AI News Aggregator"
VERSION=1.0.0
DEFAULT_LANGUAGE=it

# ================================
# Database
# ================================
DATABASE_URL=sqlite:///./data/ai_news.db
# For production: DATABASE_URL=postgresql://user:pass@localhost/ainews

# ================================
# Telegram Bot
# ================================
# Get from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Channel ID (can be @channelname or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel

# ================================
# OpenRouter / LLM
# ================================
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=moonshotai/kimi-k2.5
LLM_TEMPERATURE=0.3

# Alternative: use proxy
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ================================
# News Sources - Enable/Disable
# ================================
ENABLE_HACKERNEWS=true
ENABLE_REDDIT=true
ENABLE_DEVTO=false

# ================================
# Reddit API (optional)
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ai-news-aggregator/1.0 by u/yourusername

# Target subreddits (comma-separated)
REDDIT_SUBREDDITS=artificial,machinelearning,LocalLLaMA,ChatGPT

# ================================
# Scheduling
# ================================
# How often to fetch (minutes)
FETCH_INTERVAL_MINUTES=120

# How often to deliver (minutes)
DELIVERY_INTERVAL_MINUTES=360

# Max articles per fetch
FETCH_LIMIT=30

# Max articles per delivery
DELIVERY_LIMIT=5

# Auto-approve threshold (score >= this value)
AUTO_APPROVE_THRESHOLD=7.0

# Enable automatic delivery
ENABLE_AUTOMATIC_DELIVERY=true

# ================================
# HackerNews
# ================================
HN_STORY_TYPE=top  # top, best, ask, show
HN_MIN_SCORE=50
